# Copy to .env and adjust. See README for Docker volumes / AWS_SHARED_CREDENTIALS_FILE.

# Host and port for the status web UI (no auth — use only on trusted networks).
HOST=0.0.0.0
PORT=8080

# Seconds between poll cycles (public IP check + Route53 reconcile).
# Default if unset: 14400 (4 hours).
POLL_INTERVAL_SECONDS=14400

# Public IPv4 discovery (default matches DESIGN).
CHECKIP_URL=https://checkip.amazonaws.com

# Path to a JSON file on disk listing Route53 records (array of objects).
# Each object: hosted_zone_id, record_name (FQDN), optional ttl, optional txt_record_name.
# In Docker, mount this file as a volume and set the path inside the container.
ROUTE53_RECORDS_FILE=/path/to/records.json

# AWS credentials: use AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, or a profile file:
# AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws_credentials
# (Mount a Docker secret or credentials file at that path; see README.)
