# Copy to .env and adjust. See README for CONFIG_FILE, Docker volumes, and AWS.

# Host and port for the status web UI (no auth — use only on trusted networks).
HOST=0.0.0.0
PORT=8080

# Path to the YAML config file (poll interval, checkip URL, Route53 records, notifications).
# Default if unset: config.yaml (run from the repository root for local development).
# In Docker, the image defaults CONFIG_FILE to /config.yaml.
CONFIG_FILE=config.yaml

# Optional: owner/repo for "update available" in the footer (GitHub Releases API).
# If unset, defaults to the Repository URL in pyproject.toml (borzilleri/route53_ddns).
# Set to empty (GITHUB_REPOSITORY=) to disable the GitHub check and only show the app version.
# GITHUB_REPOSITORY=myfork/route53-ddns
# Optional override of the API base (default https://api.github.com).
# GITHUB_API_BASE=https://api.github.com

# AWS credentials: use AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, or a profile file:
# AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws_credentials
# (Mount a Docker secret or credentials file at that path; see README.)
